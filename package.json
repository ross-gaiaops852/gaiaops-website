{
  "name": "popular-phase",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "sync": "astro sync",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run lint:check && npm run format:check && npm run check",
    "check-links": "node scripts/check-links.mjs",
    "check-links:local": "npm run build && npm run check-links",
    "deploy:dev": "npm run build && echo 'Ready for development deployment'",
    "deploy:prod": "npm run build && echo 'Ready for production deployment'"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^6.0.2",
    "heroicons": "^2.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.1",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.37.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.4.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.57.0"
  }
}
